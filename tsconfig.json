{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "verbatimModuleSyntax": true,
    "resolvePackageJsonExports": true,

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "outDir": "dist",
    "noEmit": false
  },

  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
