{
  "name": "service-scan",
  "version": "1.0.0",
  "description": "service scanner pour la suite de cyber-sécurité",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest --coverage",
    "test:ci": "vitest --run",
    "sanity": "node sanity.js full",
    "sanity:lite": "node sanity.js lite",
    "prepare": "husky install",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "security",
    "scanner",
    "vulnerability",
    "detection",
    "lib-scan"
  ],
  "author": "Jérémy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/j3r3mcdev/lib-scan.git"
  },
  "bugs": {
    "url": "https://github.com/j3r3mcdev/lib-scan/issues"
  },
  "homepage": "https://github.com/j3r3mcdev/lib-scan#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@vitest/coverage-v8": "^1.6.1",
    "esbuild": "^0.21.5",
    "husky": "^9.1.7",
    "rimraf": "^5.0.5",
    "typescript": "5.4.5",
    "vite": "^5.2.10",
    "vite-node": "^1.6.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@j3r3mcdev/lib-scan": "^1.0.5"
  }
}
